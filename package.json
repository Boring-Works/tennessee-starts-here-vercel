{
	"name": "tennessee-starts-here",
	"version": "0.2.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"format": "biome format --write .",
		"prepare": "husky",
		"validate:data": "npx tsx scripts/validate-data.ts",
		"validate:facts": "npx tsx scripts/validate-facts.ts",
		"check:facts": "npx tsx scripts/validate-facts.ts",
		"check:facts:fast": "npx tsx scripts/check-facts-parallel.ts",
		"check:all": "npm run check:facts:fast",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"preview:cf": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
		"deploy:cf": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
		"test": "vitest run"
	},
	"lint-staged": {
		"*.{ts,tsx,js,mjs,json,css}": [
			"biome check --write --no-errors-on-unmatched"
		]
	},
	"dependencies": {
		"@opennextjs/cloudflare": "^1.20.1",
		"@radix-ui/react-dialog": "^1.1.17",
		"@radix-ui/react-hover-card": "^1.1.17",
		"@radix-ui/react-navigation-menu": "^1.2.16",
		"@radix-ui/react-visually-hidden": "^1.2.4",
		"@tailwindcss/typography": "^0.5.20",
		"@trigger.dev/sdk": "^4.4.6",
		"@vercel/analytics": "^1.6.1",
		"@vercel/speed-insights": "^1.3.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"framer-motion": "^12.42.0",
		"gray-matter": "^4.0.3",
		"lucide-react": "^1.22.0",
		"next": "^16.1.6",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-markdown": "^10.1.0",
		"rehype-raw": "^7.0.0",
		"rehype-sanitize": "^6.0.0",
		"suncalc": "^1.9.0",
		"tailwind-merge": "^3.6.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.1",
		"@tailwindcss/postcss": "^4",
		"@types/glob": "^9.0.0",
		"@types/node": "^20",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@types/suncalc": "^1.9.2",
		"@vitejs/plugin-react": "^5.1.4",
		"glob": "^13.0.6",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"tailwindcss": "^4",
		"typescript": "^5.9.3",
		"vite-tsconfig-paths": "^6.1.1",
		"vitest": "^4.1.9",
		"wrangler": "^4.105.0"
	},
	"overrides": {
		"@isaacs/brace-expansion": "^5.0.1",
		"cookie": "^0.7.0",
		"systeminformation": "^5.31.0",
		"minimatch": "^10.2.1"
	}
}
